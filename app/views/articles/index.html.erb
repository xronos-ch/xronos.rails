<%= content_for :head do %>
  <%= tag.link rel: "alternate", type: "application/atom+xml", href: url_for(format: :atom) %>
  <%= tag.link rel: "alternate", type: "application/rss+xml", href: url_for(format: :rss) %>
<% end %>

<header>
  <div class="container my-5 d-flex flex-row">
    <div>
      <h1 class="display-3">News</h1>
      <h2 class="h2 text-muted">From the XRONOS team</h2>
    </div>
    <% if can? :manage, Article %>
      <div class="ms-auto">
        <%= link_to 'Manage', admin_articles_path, class: 'btn btn-outline-primary' %>
      </div>
    <% end %>
  </div>
</header>

<% unless @articles.blank? %>
  <div class="bg-light">
    <div class="container my-5">
      <% @articles.each do |article| %>
        <%= render "card", article: article %>
      <% end %>

      <% unless @pagy.pages < 2 %>
        <%== @pagy.series_nav(:bootstrap) %>
      <% end %>
    </div>
  </div>
<% end %>
