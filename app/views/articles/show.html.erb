<% article_description = truncate(strip_tags(@article.body_html).squish.presence || @article.title, length: 160) %>
<% content_for :title, @article.title %>
<% content_for :meta_description, article_description %>

<% if @article.splash.present? %>
  <% content_for :page_styles %>
  <style>
    .article-hero {
      height: 20rem;
      background: none !important;
    }

    .article-hero:before {
      content: "";
      display: block;
      position: absolute;
      height: 20rem;
      width: 100%;
      z-index: -1;
      background-image: url('<%= url_for(@article.splash_variant(:xs)) %>');
      background-size: cover;
      background-position: center center;
    }

    @media (min-width: 576px)  { 
      .article-hero:before { background-image: url('<%= url_for(@article.splash_variant(:sm)) %>'); }
    }
    @media (min-width: 768px)  { 
      .article-hero:before { background-image: url('<%= url_for(@article.splash_variant(:md)) %>'); }
    }
    @media (min-width: 992px)  { 
      .article-hero:before { background-image: url('<%= url_for(@article.splash_variant(:lg)) %>'); }
    }
    @media (min-width: 1200px) { 
      .article-hero:before { background-image: url('<%= url_for(@article.splash_variant(:xl)) %>'); }
    }
    @media (min-width: 1400px) { 
      .article-hero:before { background-image: url('<%= url_for(@article.splash_variant(:xxl)) %>'); }
    }
  </style>
<% end %>

<header class="bg-light article-hero d-flex flex-column justify-content-end position-relative">
  <div class="container my-3">
    <% if @article.news_section? %>
      <span class="badge bg-primary text-uppercase">News</span>
    <% end %>
    <% if @article.splash.present? %>
      <h1 class="display-3 text-light" style="text-shadow: var(--bs-dark) 0 0 1rem;"><%= @article.title %></h1>
    <% else %>
      <h1 class="display-3 text-primary"><%= @article.title %></h1>
    <% end %>
  </div>
</header>

<div class="container my-5">
  <div class="row">

    <div class="col-lg-9">
      <div style="max-width: 720px;">
        <%= @article.body_html.html_safe %>
      </div>
    </div>

    <div class="col-lg-3">
      <%= render "users/card", user: @article.user if @article.news_section? %>

      <hr>

      <% if @article.about_section? and @article.toc.children.present? %>
        <nav id="toc">
          <h2 class="text-body-secondary text-uppercase small">On this page</h2>
          <ul class="nav flex-column mb-3">
            <%= render partial: "toc_node", collection: @article.toc.children %>
          </ul>
        </nav>
      <% end %>

      <div class="small text-body-secondary">
        <p class="mb-3">
          <% if @article.news_section? %>
            Published <%= @article.published_at.present? ? @article.published_at.strftime("%F") : "draft" %>
          <% else %>
            Last updated <%= @article.updated_at.strftime("%F") %>
          <% end %>
        </p>

        <% if @article.splash_attribution? %>
          <p class="mb-3">Cover image: <%= @article.splash_attribution.html_safe %></p>
        <% end %>

        <p>
          Cite this <%= @article.news_section? ? "article" : "page" %> as:<br>
          <%= article_citation(@article).html_safe %><br><br>
          <a href="/about/citation">More information about citing XRONOS</a>
        </p>

      </div>
    </div>

  </div>
</div>

