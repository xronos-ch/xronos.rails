<dl>

      <dt>Site</dt>
      <dd><%= link_to c14.site.name, c14.site  %></dd>

      <dt>Context</dt>
      <dd><%= c14.context.name %></dd>

        <dt>Functional classification</dt>
        <dd>
          <% if c14.context&.functional_classifications&.any? %>
            <% c14.context.functional_classifications.each do |classification| %>
              <%= classification.functional_classification_category.name.humanize %>, <%= classification.confidence.humanize %>
            <% end %>
          <% else %>
            <%= na_value %>
          <% end %>
        </dd>

</dl>

