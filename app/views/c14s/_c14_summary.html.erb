<section id="c14-summary" class="mb-5">
  <div class="row g-3">

    <div class="col-6 col-lg-3">
      <div class="section-with-legend position-relative h-100">
        <h3 class="legend">
          <%= bs_icon "flask", class: "me-1" %>Measurement
          <%= link_to "#c14-measurement", class: "text-muted text-decoration-none ms-1" do %>
            <%= bs_icon "arrow-right" %>
          <% end %>
        </h3>
        <div class="section-body h-100">
          <div class="h4 font-monospace my-1">
            <% if @c14.bp.present? %>
              <%= @c14.bp %><% if @c14.std.present? %><small>&plusmn;<%= @c14.std %></small><% end %>
            <% else %>
              <%= na_value %>
            <% end %>
          </div>
          <div class="small text-muted">uncal BP</div>
        </div>
      </div>
    </div>

    <div class="col-6 col-lg-3">
      <div class="section-with-legend position-relative h-100">
        <h3 class="legend">
          <%= bs_icon "graph-down", class: "me-1" %>Calibration
          <%= link_to "#c14-calibration", class: "text-muted text-decoration-none ms-1" do %>
            <%= bs_icon "arrow-right" %>
          <% end %>
        </h3>
        <div class="section-body h-100">
          <div class="h4 font-monospace my-1">
            <% if @calibration&.tpq.present? %>
              <%= @calibration.range.join("–") %>&nbsp;<small>cal BP</small>
            <% else %>
              <%= na_value %>
            <% end %>
          </div>
          <div class="small text-muted">95.4% probability range</div>
        </div>
      </div>
    </div>

    <div class="col-6 col-lg-3">
      <div class="section-with-legend position-relative h-100">
        <h3 class="legend">
          <%= bs_icon "archive", class: "me-1" %>Sample
          <%= link_to "#c14-sample", class: "text-muted text-decoration-none ms-1" do %>
            <%= bs_icon "arrow-right" %>
          <% end %>
        </h3>
        <div class="section-body h-100">
          <div class="h4 my-1">
            <%= @c14.sample.material&.name || na_value %>
          </div>
          <div class="small text-muted">
            <% if @c14.sample.taxon.present? %>
              <em><%= @c14.sample.taxon.name %></em>
            <% else %>
              no taxon recorded
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <div class="col-6 col-lg-3">
      <div class="section-with-legend position-relative h-100">
        <h3 class="legend">
          <%= bs_icon "diagram-3", class: "me-1" %>Context
          <%= link_to "#c14-context", class: "text-muted text-decoration-none ms-1" do %>
            <%= bs_icon "arrow-right" %>
          <% end %>
        </h3>
        <div class="section-body h-100">
          <div class="h4 my-1">
            <%= @c14.site.name %>
          </div>
          <div class="small text-muted">
            <%= @c14.context&.name || na_value %>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
