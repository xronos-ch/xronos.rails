<% content_for :title, "#{@c14.lab_identifier}, #{C14.label} from #{@c14.site.name}" %>
<% content_for :meta_description do %>
  <%= @c14.site.name %> (<%= @c14.site.country %>) has been radiocarbon dated to <%= @c14.calibration.range.join("–").html_safe %> (<%= @c14.uncal_age %> uncal BP). This determination is designated by the laboratory identifier <%= @c14.lab_identifier %> and was made on a sample of <%= @c14.sample.material.name %> (<%= @c14.sample.taxon.present? ? @c14.sample.taxon.name : "taxon unknown" %>). XRONOS' record for this radiocarbon date may include further information on the laboratory measurement, archaeological context, and bibliographic references.
<% end %>

<main class="container my-5">

  <header id="c14-header" class="mb-5">

    <div class="d-flex align-items-baseline mb-3">
      <h1 class="display-3 mb-0 me-3"><%= @c14.lab_id %></h1>
      <% if can? :edit, @c14 %>
        <%= link_to edit_icon,
          edit_c14_path(@c14),
          title: "Edit radiocarbon date",
          class: "btn btn-sm btn-outline-primary",
          data: { turbo_frame: "remote_modal" } %>
      <% end %>
    </div>

    <div class="h5 text-muted">
      Radiocarbon date from <%= link_to @c14.site.name, @c14.site %>
      <% unless @c14.site.country.blank? %>(<%= @c14.site.country %>)<% end %>
    </div>

  </header>

  <%= render "c14_summary" %>

  <div class="row g-4">

    <div class="col-12 col-lg-8">

      <section id="c14-measurement">
        <h2>Measurement</h2>
        <%= render "c14_measurement", c14: @c14 %>
      </section>

      <hr class="my-5">

      <section id="c14-calibration">
        <h2>Calibration</h2>
        <%= render "c14_calibration" %>
      </section>

      <hr class="my-5">

      <section id="c14-sample">
        <h2>Sample</h2>
        <%= render "samples/sample", sample: @c14.sample %>
      </section>

      <hr class="my-5">

      <section id="c14-context">
        <h2>Context</h2>
        <%= render "c14_context", c14: @c14 %>
      </section>

      <hr class="my-5">

      <% references = (@c14.references + @c14.site.references).uniq %>
      <section id="c14-references">
        <h2>
          <%= Reference.label.humanize.pluralize %>
          <small class="text-muted">(<%= references.count %>)</small>
        </h2>
        <%= render "references/bibliography", references: references %>
      </section>

    </div>

    <aside class="col-lg-4">
      <div class="mb-lg-5">
        <%= render "shared/record_metadata", record: @c14 %>
      </div>

      <hr class="my-5 d-lg-none">

      <section id="c14-linked-data" class="my-lg-5">
        <h2 class="h5-lg">Linked data</h2>
        <%= render "c14_linked_data" %>
      </section>

      <hr class="my-5 d-lg-none">

      <section id="c14-changelog" class="mt-lg-5">
        <h2 class="h5-lg">Changelog</h2>
        <%= render "application/paper_trail/versions", item: @c14, versions: @versions %>
      </section>
    </aside>

  </div>

</main>
