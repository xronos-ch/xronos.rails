<% content_for :title, "#{@c14.lab_identifier}, #{C14.label} from #{@c14.site.name}" %>
<% content_for :meta_description do %>
  <%= @c14.site.name %> (<%= @c14.site.country %>) has been radiocarbon dated to <%= @c14.calibration.range.join("–").html_safe %> (<%= @c14.uncal_age %> uncal BP). This determination is designated by the laboratory identifier <%= @c14.lab_identifier %> and was made on a sample of <%= @c14.sample.material.name %> (<%= @c14.sample.taxon.present? ? @c14.sample.taxon.name : "taxon unknown" %>). XRONOS' record for this radiocarbon date may include further information on the laboratory measurement, archaeological context, and bibliographic references.
<% end %>

<main class="container my-5">

  <header id="c14-header" class="mb-3">

    <div class="text-uppercase small d-flex align-items-center">
      <%= xr_icon C14, {}, { class: "me-2", style: "width: auto; height: 1rem;" } %>
      <span><%= C14.label %></span>
      <span class="vr mx-2"></span>
      <%= link_to "XRONOS", root_path, class: "text-body-secondary text-decoration-none" %>
    </div>

    <div class="d-flex align-items-baseline mb-2">
      <h1 class="mb-0 me-3"><%= @c14.lab_id %></h1>
    </div>

    <div class="lead text-body-secondary d-flex align-items-end flex-wrap">
      <div class="d-flex align-items-center">
        <%= bs_icon "globe", class: "me-2" %>
        <nav aria-label="Geographic location">
          <ol class="breadcrumb breadcrumb-chevron mb-0">
            <% unless @c14.site.country.blank? %>
              <li class="breadcrumb-item"><%= @c14.site.country %></li>
            <% end %>
            <li class="breadcrumb-item">
              <%= link_to @c14.site.name, @c14.site %>
            </li>
            <li class="breadcrumb-item active" aria-current="page"><%= @c14.lab_id %></li>
          </ol>
        </nav>
      </div>
      <% unless @c14.site.coordinates.blank? %>
        <div class="d-flex align-items-center ms-auto small">
          <%= bs_icon "geo-alt", class: "me-2" %>
          <span class="font-monospace"><%= @c14.site.coordinates.to_s("dd") %></span>
        </div>
      <% end %>
    </div>

    <div class="d-flex align-items-center text-body-secondary small mt-2">
      <%= bs_icon "link-45deg", class: "me-2" %>
      <span class="font-monospace text-truncate"><%= c14_url(@c14) %></span>
      <button type="button"
              class="btn btn-sm btn-link p-0 ms-2"
              data-controller="clipboard"
              data-clipboard-text-value="<%= c14_url(@c14) %>"
              data-action="clipboard#copy"
              title="Copy permalink">
        <%= bs_icon "clipboard" %>
      </button>
    </div>

  </header>

  <div class="mb-5">
    <%= render "shared/record_toolbar", record: @c14,
          downloads: [{ name: "JSON", path: c14_path(@c14, format: :json) }] %>
  </div>

  <%= render "c14_summary" %>

  <div class="row g-4">

    <div class="col-12 col-lg-8">

      <section id="c14-measurement">
        <h2>Measurement</h2>
        <%= render "c14_measurement", c14: @c14 %>
      </section>

      <section id="c14-calibration" class="mt-5">
        <h2>Calibration</h2>
        <%= render "c14_calibration" %>
      </section>

      <section id="c14-sample" class="mt-5">
        <h2>Sample</h2>
        <%= render "samples/sample", sample: @c14.sample %>
      </section>

      <section id="c14-context" class="mt-5">
        <h2>Context</h2>
        <%= render "c14_context", c14: @c14 %>
      </section>

      <% references = (@c14.references + @c14.site.references).uniq %>
      <section id="c14-references" class="mt-5">
        <h2>
          <%= Reference.label.humanize.pluralize %>
          <small class="text-muted">(<%= references.count %>)</small>
        </h2>
        <%= render "references/bibliography", references: references %>
      </section>

    </div>

    <aside class="col-lg-4">
      <div>
        <%= render "shared/record_metadata", record: @c14 %>
      </div>

      <section id="c14-linked-data" class="mt-5">
        <h2 class="h5-lg">Linked data</h2>
        <%= render "c14_linked_data" %>
      </section>

      <section id="c14-changelog" class="mt-5">
        <h2 class="h5-lg">Changelog</h2>
        <%= render "application/paper_trail/versions", item: @c14, versions: @versions %>
      </section>
    </aside>

  </div>

</main>
