<%= turbo_frame_tag taxon_usage do %>
  <% if taxon_usage.blank? %>
    <%= na_value %>
  <% else %>
    <% if taxon_usage.failed? %>
      <span class="text-danger">GBIF data unavailable</span>

    <% elsif taxon_usage.present? %>
      <span class="badge text-bg-info"><%= taxon_usage.rank %></span>
      <a href="<%= taxon_usage.url %>" title="gbif:<%= taxon_usage.id %>">
        <i><%= taxon_usage.canonical_name %></i> <%= taxon_usage.authorship %>
      </a>

    <% else %>
      <%= na_value %>
    <% end %>

  <% end %>
<% end %>
