<ol class="timeline">
  <% versions.reverse_each do |version| %>
    <li class="timeline-item">
      <span class="timeline-marker"></span>
      <div class="timeline-body">
        <div class="d-flex align-items-baseline gap-2 small">
          <span class="font-monospace text-body-secondary">
            <%= version.created_at.strftime("%F %H:%M") %>
          </span>
          <%= render "application/paper_trail/whodunnit", version: version %>
        </div>
        <% if version.changeset.any? { |c| c.first != "updated_at" } %>
          <details class="timeline-changes">
            <summary title="Show/hide changes">
              <%= version.revision_comment.blank? ? "Updated." : md(version.revision_comment) %>
            </summary>
            <%= render "application/paper_trail/changes", version: version %>
          </details>
        <% else %>
          <div class="small">
            <%= version.revision_comment.blank? ? "Updated." : md(version.revision_comment) %>
          </div>
        <% end %>
      </div>
    </li>
  <% end %>
</ol>
