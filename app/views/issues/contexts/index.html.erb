<% content_for :title, "Issues – Contexts" %>
<% content_for :help do %>
<% end %>

<h2 class="border-bottom">Contexts</h2>

<%= render "issues/nav", model: ::Context, base_path: issues_contexts_path %>

<turbo-frame id="issues-contexts-table">
  <%= render "issues/filter_form" %>

  <div class="mb-2 d-flex gap-2 align-items-center">
    <%= link_to "All contexts",
                issues_contexts_path,
                class: "btn btn-sm #{params[:suggestions].present? ? 'btn-outline-secondary' : 'btn-secondary'}",
                data: { turbo_frame: "issues-contexts-table" } %>

    <% suggestions_button_class =
         if @suggestions_count.zero?
           "btn btn-sm btn-outline-secondary disabled"
         elsif params[:suggestions].present?
           "btn btn-sm btn-secondary"
         else
           "btn btn-sm btn-outline-secondary"
         end %>

    <%= link_to "With suggestions (#{@suggestions_count})",
                @suggestions_count.zero? ? "#" : issues_contexts_path(suggestions: 1),
                class: suggestions_button_class,
                aria: { disabled: @suggestions_count.zero? },
                data: {
                  turbo_frame: @suggestions_count.zero? ? nil : "issues-contexts-table"
                } %>
  </div>

  <%= render "table", contexts: @contexts %>
  <%== @pagy.series_nav(:bootstrap) %>
</turbo-frame>
