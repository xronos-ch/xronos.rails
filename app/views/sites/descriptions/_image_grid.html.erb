<% layout = site_description_image_grid_layout(images.length) %>

<div style="display: grid; grid-template-columns: <%= layout[:columns] %>; grid-template-rows: <%= layout[:rows] %>; aspect-ratio: 4 / 3; gap: 0.5rem;">
  <% images.each_with_index do |image, i| %>
    <% cell = layout[:cells][i] %>
    <div style="grid-column: <%= cell[:grid_column] %>; grid-row: <%= cell[:grid_row] %>; overflow: hidden; border-radius: 0.25rem;">
      <a href="<%= image[:page_url] %>" target="_blank" rel="noopener" title="View on Wikimedia Commons" style="display: block; height: 100%;">
        <img src="<%= image[:thumb_url] %>" alt="<%= image[:basename].tr('_', ' ') %>" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;" />
      </a>
    </div>
  <% end %>
</div>

<% if commons_category_url.present? && commons_category_title.present? %>
  <p class="small text-muted mt-2 mb-0">
    <a href="<%= commons_category_url %>" target="_blank" rel="noopener">
      Images related to <%= commons_category_title %> on Wikimedia Commons
    </a>
  </p>
<% end %>
