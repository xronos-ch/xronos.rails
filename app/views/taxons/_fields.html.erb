<%= f.text_field :name,
      data: {
        controller: "tom-select",
        tom_select_route_value: "gbif_search",
        tom_select_value_value: "label",
        tom_select_label_value: "label", # TODO check
        tom_select_search_value: "label" # TODO check
      } %>
<%= f.hidden_field :gbif_id %>
<% if @taxon.gbif_id.present? %>
  <div class="mb-3 small text-success">
    <%= bs_icon "check-lg" %>
    Matched to GBIF Backbone Taxonomy:
    <%= render @taxon.usage %>
  </div>
<% else %>
  <div class="mb-3 small text-warning">
    <%= bs_icon "exclamation-circle", title: "Warning" %>
    Name not matched to GBIF Backbone Taxonomy.
  </div>
<% end %>
