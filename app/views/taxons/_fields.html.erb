<div data-controller="taxon-field">
  <%= f.text_field :gbif_id, data: { taxon_field_target: "gbifIdField" } %>
  <%= f.text_field :name,
    floating: true,
    data: {
      controller: "tom-select",
      taxon_field_target: "nameField",
      tom_select_route_value: "taxons",
      tom_select_search_mode_value: true,
      tom_select_value_value: "gbif_id",
      tom_select_label_value: "name", # TODO check
      tom_select_search_value: "name", # TODO check
      tom_select_params_value: "search_gbif&matched_only",
      tom_select_max_items_value: 1,
      tom_select_create_value: true
    } %>
</div>
<% if @taxon.gbif_id.present? %>
  <div class="mb-3 small text-success">
    <%= bs_icon "check-lg" %>
    Matched to GBIF Backbone Taxonomy:
    <%= render @taxon.usage %>
  </div>
<% else %>
  <div class="mb-3 small text-warning">
    <%= bs_icon "exclamation-circle", title: "Warning" %>
    Name not matched to GBIF Backbone Taxonomy.
  </div>
<% end %>
