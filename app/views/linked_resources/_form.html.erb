<%= bootstrap_form_with(model: @linked_resource, id: "linkedResourceForm") do |f| %>
  <%= render  "fields", f: f %>

  <%= content_for :buttons do %>
    <%= button_tag "Cancel", type: "reset", class: "btn btn-outline-danger",
      form: "linkedResourceForm", data: { "bs-dismiss": "modal" } %>
    <%= button_tag "Save", class: "btn btn-primary", form: "linkedResourceForm" %>
  <% end %>
<% end %>
