<%= turbo_frame_tag lod_link do %>
  <dl class="row mb-0 align-items-center">
    <dt class="col-sm-3 text-muted">
      <%= simple_icon lod_link.source.downcase %>
      <span class="ms-1"><%= lod_link.source %></span>
    </dt>
    <dd class="col-sm-9 mb-0 d-flex align-items-center gap-2">
      <span>
        <% if lod_link.external_url.present? %>
          <%= link_to lod_link.qcode, lod_link.external_url,
                      title: "#{lod_link.source} identifier corresponding to this record",
                      target: "_blank", rel: "noopener" %>
        <% else %>
          <span class="text-muted"><%= lod_link.qcode %></span>
        <% end %>
        <% if lod_link.pending? %>
          <span class="badge text-bg-warning ms-2">pending</span>
        <% end %>
      </span>
      <% if can? :manage, LodLink %>
        <%= link_to edit_lod_link_path(lod_link),
                    class: "small",
                    title: "Edit #{lod_link.source} link",
                    data: { turbo_frame: "remote_modal" } do %>
          <%= bs_icon "pencil" %>
        <% end %>
      <% end %>
    </dd>
  </dl>
<% end %>
