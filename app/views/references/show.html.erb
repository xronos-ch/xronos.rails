<% content_for :title, "#{@reference.render_citation}, #{Reference.label.downcase}" %>
<% content_for :meta_description,
   "#{@reference.render_citation} is cited by #{@citations_count} records of archaeological sites, radiocarbon dates, and/or other chronometric determinations in the XRONOS repository." %>

<main class="container my-5">

  <header id="reference-header" class="mb-3">

    <div class="text-uppercase small d-flex align-items-center">
      <%= xr_icon Reference, {}, { class: "me-2", style: "width: auto; height: 1rem;" } %>
      <span><%= Reference.label %></span>
      <span class="vr mx-2"></span>
      <%= link_to "XRONOS", root_path, class: "text-body-secondary text-decoration-none" %>
    </div>

    <div class="d-flex align-items-baseline mb-2">
      <h1 class="mb-0 me-3"><%= @reference.render_citation %></h1>
    </div>

    <div class="lead text-body-secondary">
      <%= @reference.render %>
    </div>

    <div class="d-flex align-items-center text-body-secondary small mt-2">
      <%= bs_icon "link-45deg", class: "me-2" %>
      <span class="font-monospace text-truncate"><%= reference_url(@reference) %></span>
      <button type="button"
              class="btn btn-sm btn-link p-0 ms-2"
              data-controller="clipboard"
              data-clipboard-text-value="<%= reference_url(@reference) %>"
              data-action="clipboard#copy"
              title="Copy permalink">
        <%= bs_icon "clipboard" %>
      </button>
    </div>

  </header>

  <div class="mt-3">
    <%= render "shared/record_metadata", record: @reference %>
  </div>

  <div class="mt-3 mb-5">
    <%= render "shared/record_toolbar", record: @reference, downloads: [] %>
  </div>

  <section id="reference-details" class="my-5">
    <%= render "bibliography", references: [@reference] %>
  </section>

  <section id="reference-citations" class="my-5">
    <h2>Citing records</h2>
    <% c = @citations_count %>
    <p>There <%= c > 1 ? 'are' : 'is' %> <%= c %> <%= 'record'.pluralize(c) %>
        in XRONOS that <%= c > 1 ? 'cite' : 'cites' %> this reference.</p>

    <% if @sites.present? %>
      <div class="my-5">
        <h3>
          <%= xr_icon Site, {}, style: "height: 1.75rem; vertical-align: top;" %>
          <%= Site.label.humanize.pluralize %>
          <small class="text-muted">(<%= @pagy_sites.count %>)</small>
        </h3>
        <turbo-frame id="reference-sites-table">
          <%= render "sites/table", sites: @sites %>
          <% unless @pagy_sites.pages <= 1 %>
            <%== @pagy_sites.series_nav(:bootstrap) %>
          <% end %>
        </turbo-frame>
      </div>
    <% end %>
  </section>

  <div class="my-5">
    <h2>Changelog</h2>
    <%= render "application/paper_trail/versions", item: @reference %>
  </div>

</main>
